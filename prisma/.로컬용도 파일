// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = "postgresql://postgres.kjstzjqwqstglbcyskk:0114252544as@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
  directUrl = "postgresql://postgres:0114252544as@db.kjstzjqwqstglbcyskk.supabase.co:5432/postgres"
