// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

model Record {
  id        Int      @id @default(autoincrement())
  title     String
  content   String 
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fileUrl String[]
  userId    Int      
  user      User     @relation(fields: [userId], references: [id])

  @@map("Record")
}

model WorkoutRecord {
  id          Int      @id @default(autoincrement())
  date        DateTime // 운동 날짜
  workoutName String   // 운동 이름
  reps        Int      // 횟수
  sets        Int      // 세트 수
  restTime    Int      // 휴식 시간 (분)
  userId      String   // 사용자 연결용
  createdAt   DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement()) 
  userId    String   @unique                       
  name      String                                 
  email     String   @unique                       
  password  String                                 
  createdAt DateTime @default(now())     

  records   Record[]          
}